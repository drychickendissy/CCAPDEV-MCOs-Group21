# Local dev defaults — copy to `.env` and replace values for your environment
PORT=3000
# For MongoDB Atlas use the SRV connection string, for example:
# mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/animocommons?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/animo_commons
# Some hosting platforms use the name MONGO_URI instead; our code accepts both.
# MONGO_URI=
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

