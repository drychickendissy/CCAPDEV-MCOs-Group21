{{!
  ### `src/views/sign-up.hbs`
  - Sign-up form template.
  - Collects username/email/password and links back to login.

  Sign Up page template
  Provides a registration form for new users to create an account
}}
<div class="sign-up-container">
  <div class="sign-up-banner">
    <h2 class="poppins-extrabold">Join the Commons, Archer!</h2>
    <p class="poppins-regular">Discover and explore what the Commons is up to today!</p>
  </div>
  <div class="sign-up-form-container">
    <div class="sign-up-form">
      <h1 class="poppins-extrabold">Sign Up</h1>
      <form id="sign-up-form">
        <input type="text" id="username" placeholder="Username" required>
        <input type="email" id="email" placeholder="Email" required>
        <input type="password" id="password" placeholder="Password" required>
        <button type="submit" class="poppins-regular">Sign Up</button>
      </form>
      <p class="poppins-regular">Already have an account? <a href="/login" class="poppins-regular">Login here</a></p>
    </div>
  </div>
</div>
